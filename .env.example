# ── Required ───────────────────────────────────────────────────────────────────
BOT_TOKEN=123456789:ABCDefgh_your_token_here

# ── Optional ────────────────────────────────────────────────────────────────
# NOTE: Catalogue/product image URLs are no longer set here — edit
# CATALOGUE_PHOTO and OPTION_IMAGES directly in bot.py instead.

# ── Paytm / UPI merchant details — QR codes are generated automatically ───────
UPI_ID=merchant@paytm
MERCHANT_NAME=Your Business Name

# ── Channel & support ──────────────────────────────────────────────────────────
DEMO_CHANNEL=https://t.me/your_demo_channel
SUPPORT=@yoursupporthandle

# ── Railway sets PORT automatically; set WEBHOOK_URL after first deploy ────────
# e.g. https://myproxybot.up.railway.app
WEBHOOK_URL=
PORT=8080
